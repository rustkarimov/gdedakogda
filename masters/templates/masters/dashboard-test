{% extends 'masters/base.html' %}

{% block title %}Личный кабинет - {{ master.first_name }} {{ master.last_name }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tachometer-alt me-2" style="color: #ff85b3;"></i>Личный кабинет</h2>
    <div>
        <a href="{% url 'add_manual_booking' %}" class="btn btn-pink">
            <i class="fas fa-pen-alt me-1"></i>Добавить запись
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="dashboard-stat">
            <i class="fas fa-calendar-check"></i>
            <h3>{{ total_bookings }}</h3>
            <p>Всего записей</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-stat">
            <i class="fas fa-cut"></i>
            <h3>{{ total_services }}</h3>
            <p>Услуг</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-stat">
            <i class="fas fa-link"></i>
            <h3><i class="fas fa-copy copy-link" style="cursor: pointer;" onclick="copyPublicLink()"></i></h3>
            <p>Ваша ссылка</p>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="far fa-calendar-alt me-2" style="color: #ff85b3;"></i>Календарь</h5>
    </div>
    <div class="card-body">
        <div class="text-center mb-3">
            <button class="btn btn-sm btn-outline-pink" onclick="changeMonth(-1)">←</button>
            <span class="mx-3 fw-bold" id="current-month"></span>
            <button class="btn btn-sm btn-outline-pink" onclick="changeMonth(1)">→</button>
        </div>
        <div id="calendar-grid"></div>
        <div class="mt-2 small text-muted text-center">
            <span class="badge bg-success me-2">Рабочий день</span>
            <span class="badge bg-secondary me-2">Выходной</span>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-clock me-2" style="color: #ff85b3;"></i>Ближайшие записи</h5>
        <span class="badge bg-pink" id="total-bookings-count">0</span>
    </div>
    <div class="card-body">
        <div id="upcoming-bookings-container">
            <div class="text-center">
                <div class="spinner-border" style="color: #ff85b3;"></div>
            </div>
        </div>
        <div class="text-center mt-3">
            <button id="load-more-bookings" class="btn btn-outline-pink" style="display: none;" onclick="loadMoreBookings()">
                <i class="fas fa-chevron-down me-2"></i>Показать еще
            </button>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5><i class="fas fa-share-alt me-2" style="color: #ff85b3;"></i>Ваша страница для записи</h5>
        <div class="input-group">
            <input type="text" class="form-control" id="publicLink"
                value="{{ request.scheme }}://{{ request.get_host }}/{{ master.public_slug }}/" readonly>
            <button class="btn btn-pink" type="button" onclick="copyPublicLink()">
                <i class="fas fa-copy"></i> Копировать
            </button>
        </div>
        <small class="text-muted">Отправьте эту ссылку клиентам, и они смогут записаться к вам</small>
    </div>
</div>

<!-- МОДАЛЬНОЕ ОКНО -->
<div class="modal fade" id="dayModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редактирование дня</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {% csrf_token %}
                <p class="text-muted" id="dayModalDate"></p>
                <div class="alert alert-light" id="currentStatusAlert">
                    <i class="fas fa-info-circle me-2"></i> <span id="currentStatusText">Загрузка...</span>
                </div>

                <!-- Кнопки для рабочего дня (скрыты по умолчанию) -->
                <div id="workingDayActions" class="d-grid gap-2 mb-3" style="display: none;">
                    <button class="btn btn-outline-primary" onclick="showEditForm()">
                        <i class="fas fa-edit me-2"></i>Изменить время и перерывы
                    </button>
                    <button class="btn btn-outline-danger" onclick="makeDayOff()">
                        <i class="fas fa-calendar-times me-2"></i>Сделать выходным
                    </button>
                </div>

                <!-- Кнопка для выходного дня (скрыта по умолчанию) -->
                <div id="dayOffActions" class="d-grid gap-2 mb-3" style="display: none;">
                    <button class="btn btn-outline-success" onclick="makeWorkingFromDayOff()">
                        <i class="fas fa-calendar-check me-2"></i>Сделать рабочим днём
                    </button>
                </div>

                <!-- Форма редактирования -->
                <div id="editFormBlock" style="display: none;">
                    <hr>
                    <h6 class="mb-3">Настройка времени</h6>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label">Начало работы</label>
                            <input type="time" class="form-control" id="extraStartTime">
                        </div>
                        <div class="col-6">
                            <label class="form-label">Конец работы</label>
                            <input type="time" class="form-control" id="extraEndTime">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Перерывы</label>
                        <div id="extraBreaksContainer">
                            <div class="break-item row g-2 mb-2">
                                <div class="col-5">
                                    <input type="time" class="form-control form-control-sm break-start" placeholder="Начало">
                                </div>
                                <div class="col-5">
                                    <input type="time" class="form-control form-control-sm break-end" placeholder="Конец">
                                </div>
                                <div class="col-2">
                                    <button type="button" class="btn btn-sm btn-outline-danger w-100 remove-break">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addExtraBreakField()">
                            <i class="fas fa-plus me-1"></i>Добавить перерыв
                        </button>
                    </div>
                    <button class="btn btn-primary w-100 mt-3" id="saveDayBtn" onclick="saveDayChanges()">
                        <i class="fas fa-save me-2"></i>Сохранить изменения
                    </button>
                </div>

                <hr>
                <h6 class="mb-3"><i class="fas fa-list me-2"></i>Записи на этот день</h6>
                <div id="dayBookingsContainer">
                    <div class="text-center py-2">
                        <div class="spinner-border spinner-border-sm" style="color: #7c3aed;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<script>
function copyPublicLink() {
    const t = document.getElementById("publicLink");
    t.select();
    t.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(t.value);
    alert("Ссылка скопирована!");
}

function showPhone(e, t) {
    if (t.dataset.phoneVisible === "true") {
        t.innerHTML = '<i class="fas fa-eye-slash"></i>';
        t.classList.remove("btn-outline-pink");
        t.classList.add("btn-outline-secondary");
        t.dataset.phoneVisible = "false";
        t.nextElementSibling.style.display = "none";
    } else {
        t.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        fetch(`/api/get-decrypted-phone/${e}/`)
            .then(e => e.json())
            .then(e => {
                if (e.phone) {
                    t.innerHTML = '<i class="fas fa-eye"></i>';
                    t.classList.remove("btn-outline-secondary");
                    t.classList.add("btn-outline-pink");
                    t.dataset.phoneVisible = "true";
                    t.nextElementSibling.textContent = e.phone;
                    t.nextElementSibling.style.display = "inline";
                } else {
                    t.innerHTML = '<i class="fas fa-eye-slash"></i>';
                    alert("Ошибка при получении номера");
                }
            })
            .catch(() => {
                t.innerHTML = '<i class="fas fa-eye-slash"></i>';
                alert("Ошибка загрузки");
            });
    }
}

let currentCalendarDate = new Date(),
    currentSelectedDate = null,
    currentDayData = null;

function loadCalendar() {
    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();
    const monthNames = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь', 'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
    document.getElementById('current-month').innerHTML = `${monthNames[month]} ${year}`;

    const grid = document.getElementById('calendar-grid');
    grid.innerHTML = '<div class="text-center py-3"><div class="spinner-border" style="color: #7c3aed;"></div></div>';

    Promise.all([
        fetch('/api/schedule/calendar/').then(r => r.json()),
        fetch('/api/bookings/counts/').then(r => r.json())
    ]).then(([calendarData, countsData]) => {
        renderCalendar(calendarData, countsData, year, month);
    }).catch(error => {
        console.error(error);
        grid.innerHTML = '<div class="text-center text-danger">Ошибка загрузки</div>';
    });
}

function renderCalendar(data, countsData, year, month) {
    const firstDay = new Date(year, month, 1);
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const startWeekday = firstDay.getDay();
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    let html = '<div class="calendar-weekdays">';
    ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'].forEach(d => html += `<div class="calendar-weekday">${d}</div>`);
    html += '</div><div class="calendar-dates">';

    let adjustedStartWeekday = startWeekday === 0 ? 6 : startWeekday - 1;
    for (let i = 0; i < adjustedStartWeekday; i++) html += '<div class="calendar-date empty"></div>';

    for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const currentDate = new Date(year, month, d);
        const isPast = currentDate < today;
        const dayOfWeek = currentDate.getDay();
        const dayIdx = dayOfWeek === 0 ? 6 : dayOfWeek - 1;

        const extraDay = data.extra_days && data.extra_days[dateStr];
        const schedule = data.schedules && data.schedules[dayIdx];
        const isDayOff = data.days_off && data.days_off.includes(dateStr);
        const bookingCount = (countsData.counts && countsData.counts[dateStr]) ? countsData.counts[dateStr] : 0;

        let workingClass = '', statusText = '';

        if (isDayOff) {
            workingClass = 'non-working';
            statusText = '';  // пусто для выходных
        } else if (extraDay) {
            workingClass = 'working';
            statusText = `${extraDay.start} - ${extraDay.end}`;
        } else if (schedule) {
            workingClass = 'working';
            statusText = `${schedule.start} - ${schedule.end}`;
        } else {
            workingClass = 'non-working';
            statusText = '';  // пусто для нерабочих
        }

        if (isPast) workingClass += ' past';
        const isToday = currentDate.toDateString() === today.toDateString();
        const todayClass = isToday ? 'today' : '';

        html += `<div class="calendar-date ${workingClass} ${todayClass}" onclick="openDayModal('${dateStr}')">
                    ${d}
                    <div class="calendar-time">${statusText}</div>
                    ${bookingCount > 0 ? `<span class="booking-badge">${bookingCount}</span>` : ''}
                </div>`;
    }
    html += '</div>';
    document.getElementById('calendar-grid').innerHTML = html;
}

function changeMonth(delta) {
    currentCalendarDate.setMonth(currentCalendarDate.getMonth() + delta);
    loadCalendar();
}

function openDayModal(dateStr) {
    currentSelectedDate = dateStr;
    const dateObj = new Date(dateStr);
    const monthNames = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
    document.getElementById('dayModalDate').innerHTML = `${dateObj.getDate()} ${monthNames[dateObj.getMonth()]} ${dateObj.getFullYear()}`;

    document.getElementById('editFormBlock').style.display = 'none';
    document.getElementById('workingDayActions').style.display = 'none';
    document.getElementById('dayOffActions').style.display = 'none';
    document.getElementById('dayBookingsContainer').innerHTML = '<div class="text-center py-2"><div class="spinner-border spinner-border-sm" style="color: #7c3aed;"></div></div>';
    document.getElementById('currentStatusText').innerHTML = 'Загрузка...';

    fetch(`/api/bookings/by-date/?date=${dateStr}`)
        .then(r => r.json())
        .then(data => renderDayBookings(data.bookings));

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const isPast = new Date(dateStr) < today;

    fetch(`/api/day-status/?date=${dateStr}`)
        .then(r => r.json())
        .then(data => {
            console.log('Статус дня:', data);

            let statusText = '';

            if (data.is_day_off === true || (data.has_schedule === false && data.is_extra === false)) {
                if (data.is_day_off) {
                    statusText = 'Выходной день';
                } else {
                    statusText = 'Нерабочий день (нет расписания)';
                }
                document.getElementById('currentStatusText').innerHTML = statusText;

                if (!isPast) {
                    document.getElementById('dayOffActions').style.display = 'block';
                }
            } else {
                if (data.is_extra) {
                    statusText = `Рабочий день (дополнительный: ${data.extra_start} - ${data.extra_end})`;
                } else if (data.has_schedule) {
                    statusText = `Рабочий день (по расписанию: ${data.schedule_start} - ${data.schedule_end})`;
                }
                document.getElementById('currentStatusText').innerHTML = statusText;

                if (!isPast) {
                    document.getElementById('workingDayActions').style.display = 'block';
                }
            }

            currentDayData = data;
        });

    new bootstrap.Modal(document.getElementById('dayModal')).show();
}

function renderDayBookings(bookings) {
    const container = document.getElementById('dayBookingsContainer');
    if (!bookings || bookings.length === 0) {
        container.innerHTML = '<p class="text-muted text-center mb-0">Нет записей</p>';
        return;
    }
    let html = '<div class="table-responsive"><table class="table table-sm">';
    html += '<thead><tr><th>Время</th><th>Клиент</th><th>Услуга</th><th>Телефон</th><th>Действия</th></tr></thead><tbody>';
    bookings.forEach(b => {
        html += `<tr>
                    <td>${b.time}</td>
                    <td>${escapeHtml(b.client_name)}</td>
                    <td>${escapeHtml(b.service_name)}</td>
                    <td>${b.phone || '—'}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-pink" onclick="editBooking(${b.id})" title="Редактировать">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBooking(${b.id}, '${escapeHtml(b.client_name)}', '${b.time}')" title="Удалить">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>`;
    });
    html += '</tbody><td></div>';
    container.innerHTML = html;
}

function addExtraBreakField(s = '', e = '') {
    const c = document.getElementById('extraBreaksContainer');
    const d = document.createElement('div');
    d.className = 'break-item row g-2 mb-2';
    d.innerHTML = `
        <div class="col-5">
            <input type="time" class="form-control form-control-sm break-start" value="${s}" placeholder="Начало">
        </div>
        <div class="col-5">
            <input type="time" class="form-control form-control-sm break-end" value="${e}" placeholder="Конец">
        </div>
        <div class="col-2">
            <button type="button" class="btn btn-sm btn-outline-danger w-100 remove-break" onclick="this.closest('.break-item').remove()">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    `;
    c.appendChild(d);
}

function showEditForm() {
    document.getElementById('workingDayActions').style.display = 'none';
    document.getElementById('editFormBlock').style.display = 'block';
    document.getElementById('extraStartTime').value = currentDayData.extra_start || '09:00';
    document.getElementById('extraEndTime').value = currentDayData.extra_end || '18:00';
    document.getElementById('extraBreaksContainer').innerHTML = '';
    addExtraBreakField();
    if (currentDayData.breaks && currentDayData.breaks.length > 0) {
        currentDayData.breaks.forEach(b => addExtraBreakField(b.start, b.end));
    }
}

function makeDayOff() {
    if (!confirm('Сделать этот день выходным?')) return;
    fetch('/api/days-off/add/', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({ date: currentSelectedDate, reason: 'Выходной' })
    }).then(r => r.json()).then(d => {
        if (d.success) {
            bootstrap.Modal.getInstance(document.getElementById('dayModal')).hide();
            loadCalendar();
        }
    });
}

function makeWorkingFromDayOff() {
    document.getElementById('dayOffActions').style.display = 'none';
    document.getElementById('editFormBlock').style.display = 'block';
    document.getElementById('extraStartTime').value = '09:00';
    document.getElementById('extraEndTime').value = '18:00';
    document.getElementById('extraBreaksContainer').innerHTML = '';
    addExtraBreakField();
    document.getElementById('currentStatusText').innerHTML = 'Настройка рабочего дня';
}

function saveDayChanges() {
    const s = document.getElementById('extraStartTime').value;
    const e = document.getElementById('extraEndTime').value;
    if (!s || !e) {
        alert('Заполните время');
        return;
    }
    const breaks = [];
    document.querySelectorAll('#extraBreaksContainer .break-item').forEach(i => {
        const st = i.querySelector('.break-start').value;
        const en = i.querySelector('.break-end').value;
        if (st && en) breaks.push({ start: st, end: en });
    });
    const btn = document.getElementById('saveDayBtn');
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Сохранение...';
    btn.disabled = true;
    fetch('/api/extra-days/delete-by-date/', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({ date: currentSelectedDate })
    })
    .then(() => fetch('/api/days-off/delete-by-date/', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({ date: currentSelectedDate })
    }))
    .then(() => fetch('/api/extra-days/add/', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({
            date: currentSelectedDate,
            start_time: s,
            end_time: e,
            breaks: breaks
        })
    }))
    .then(r => r.json())
    .then(d => {
        if (d.success) {
            bootstrap.Modal.getInstance(document.getElementById('dayModal')).hide();
            loadCalendar();
        } else {
            alert(d.error || 'Ошибка');
        }
    })
    .catch(err => {
        console.error(err);
        alert('Ошибка');
    })
    .finally(() => {
        btn.innerHTML = orig;
        btn.disabled = false;
    });
}

function escapeHtml(str) {
    return str ? str.replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : m === '>' ? '&gt;' : m) : '';
}

let bookingsPage = 1, bookingsHasMore = true;

function loadBookings(p = 1, a = false) {
    fetch(`/api/bookings/?page=${p}&limit=10`)
        .then(r => r.json())
        .then(d => {
            if (a) {
                const t = document.querySelector('#upcoming-bookings-table tbody');
                d.bookings.forEach(b => {
                    const r = createBookingRow(b);
                    t.insertAdjacentHTML('beforeend', r);
                });
            } else {
                renderBookings(d.bookings);
                document.getElementById('total-bookings-count').textContent = d.total;
            }
            bookingsHasMore = d.has_more;
            bookingsPage = p;
            const btn = document.getElementById('load-more-bookings');
            btn.style.display = (bookingsHasMore && d.bookings.length > 0) ? 'inline-block' : 'none';
        });
}

function renderBookings(b) {
    const c = document.getElementById('upcoming-bookings-container');
    if (b.length === 0) {
        c.innerHTML = '<p class="text-muted mb-0">Пока нет записей</p>';
        return;
    }
    let h = '<div class="table-responsive"><table class="table" id="upcoming-bookings-table"><thead>';
    h += '<tr><th>Дата</th><th>Время</th><th>Клиент</th><th>Услуга</th><th>Телефон</th><th>Статус</th></tr>';
    h += '</thead><tbody>';
    b.forEach(bb => { h += createBookingRow(bb); });
    h += '</tbody></table></div>';
    c.innerHTML = h;
}

function createBookingRow(b) {
    return `<tr>
        <td>${b.date}</td>
        <td>${b.time}</td>
        <td>${b.client_name}</td>
        <td>${b.service_name}</td>
        <td>${b.phone || '—'}</td>
        <td>
            <button class="btn btn-sm btn-outline-pink" onclick="editBooking(${b.id})" title="Редактировать">
                <i class="fas fa-edit"></i>
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="deleteBooking(${b.id}, '${escapeHtml(b.client_name)}', '${b.time}')" title="Удалить">
                <i class="fas fa-trash"></i>
            </button>
        </td>
        <td><span class="badge bg-success">Подтверждена</span></td>
    </tr>`;
}

function loadMoreBookings() {
    if (bookingsHasMore) loadBookings(bookingsPage + 1, true);
}

document.addEventListener('DOMContentLoaded', () => {
    loadCalendar();
    loadBookings(1, false);
});
</script>

<script>

    // Модальное окно для редактирования записи
const editBookingModalHtml = `
<div class="modal fade" id="editBookingModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редактирование записи</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editBookingForm">
                    {% csrf_token %}
                    <input type="hidden" id="edit_booking_id">
                    
                    <div class="mb-3">
                        <label class="form-label">Имя клиента</label>
                        <input type="text" class="form-control" id="edit_client_name" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Телефон</label>
                        <input type="tel" class="form-control" id="edit_client_phone" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Услуга</label>
                        <select class="form-select" id="edit_service_id" required>
                            <option value="">Выберите услугу</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Дата</label>
                        <select class="form-select" id="edit_date" required>
                            <option value="">Сначала выберите услугу</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Время</label>
                        <select class="form-select" id="edit_time" required disabled>
                            <option value="">Сначала выберите дату</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Комментарий</label>
                        <textarea class="form-control" id="edit_comment" rows="2"></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Статус</label>
                        <select class="form-select" id="edit_status">
                            <option value="confirmed">Подтверждена</option>
                            <option value="cancelled">Отменена</option>
                            <option value="completed">Выполнена</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-pink" onclick="saveEditedBooking()">Сохранить</button>
            </div>
        </div>
    </div>
</div>
`;

// Добавляем модальное окно в конец body
document.body.insertAdjacentHTML('beforeend', editBookingModalHtml);

let currentEditBookingId = null;

function editBooking(bookingId) {
    currentEditBookingId = bookingId;
    
    // Загружаем данные записи
    fetch(`/api/booking/${bookingId}/get/`)
        .then(response => response.json())
        .then(data => {
            document.getElementById('edit_booking_id').value = data.id;
            document.getElementById('edit_client_name').value = data.client_name;
            document.getElementById('edit_client_phone').value = data.client_phone;
            document.getElementById('edit_comment').value = data.comment || '';
            document.getElementById('edit_status').value = data.status;
            
            // Загружаем услуги мастера
            fetch('/api/categories/')
                .then(r => r.json())
                .then(categories => {
                    let serviceHtml = '<option value="">Выберите услугу</option>';
                    categories.categories.forEach(cat => {
                        cat.services.forEach(service => {
                            serviceHtml += `<option value="${service.id}" data-duration="${service.duration}">${cat.name} - ${service.name} (${service.duration} мин, ${service.price} ₽)</option>`;
                        });
                    });
                    categories.uncategorized.forEach(service => {
                        serviceHtml += `<option value="${service.id}" data-duration="${service.duration}">${service.name} (${service.duration} мин, ${service.price} ₽)</option>`;
                    });
                    document.getElementById('edit_service_id').innerHTML = serviceHtml;
                    document.getElementById('edit_service_id').value = data.service_id;
                    
                    // Загружаем доступные даты для выбранной услуги
                    loadEditAvailableDates(data.service_id, data.date);
                });
        });
    
    new bootstrap.Modal(document.getElementById('editBookingModal')).show();
}

function loadEditAvailableDates(serviceId, selectedDate) {
    const masterSlug = document.querySelector('#publicLink')?.value.split('/').slice(-2, -1)[0] || '';
    
    fetch(`/api/${masterSlug}/dates/?service_id=${serviceId}`)
        .then(response => response.json())
        .then(data => {
            let dateHtml = '<option value="">Выберите дату</option>';
            data.dates.forEach(date => {
                const selected = date.date === selectedDate ? 'selected' : '';
                dateHtml += `<option value="${date.date}" ${selected}>${date.display}</option>`;
            });
            document.getElementById('edit_date').innerHTML = dateHtml;
            
            // Загружаем слоты для выбранной даты
            loadEditAvailableSlots(serviceId, selectedDate, selectedDate);
        });
}

function loadEditAvailableSlots(serviceId, date, selectedTime) {
    const masterSlug = document.querySelector('#publicLink')?.value.split('/').slice(-2, -1)[0] || '';
    
    fetch(`/api/${masterSlug}/slots/?service_id=${serviceId}&date=${date}`)
        .then(response => response.json())
        .then(data => {
            let timeHtml = '<option value="">Выберите время</option>';
            data.slots.forEach(slot => {
                const selected = slot.start === selectedTime ? 'selected' : '';
                timeHtml += `<option value="${slot.start}" ${selected}>${slot.start}</option>`;
            });
            document.getElementById('edit_time').innerHTML = timeHtml;
            document.getElementById('edit_time').disabled = false;
        });
}

// Обработчики изменения услуги и даты
document.addEventListener('change', function(e) {
    if (e.target.id === 'edit_service_id') {
        const serviceId = e.target.value;
        if (serviceId) {
            loadEditAvailableDates(serviceId, null);
        }
    }
    if (e.target.id === 'edit_date') {
        const date = e.target.value;
        const serviceId = document.getElementById('edit_service_id').value;
        if (date && serviceId) {
            loadEditAvailableSlots(serviceId, date, null);
        }
    }
});

function saveEditedBooking() {
    const bookingId = document.getElementById('edit_booking_id').value;
    const serviceId = document.getElementById('edit_service_id').value;
    const clientName = document.getElementById('edit_client_name').value.trim();
    const clientPhone = document.getElementById('edit_client_phone').value.trim();
    const date = document.getElementById('edit_date').value;
    const time = document.getElementById('edit_time').value;
    const comment = document.getElementById('edit_comment').value;
    const status = document.getElementById('edit_status').value;
    
    if (!serviceId || !clientName || !clientPhone || !date || !time) {
        alert('Заполните все обязательные поля');
        return;
    }
    
    const saveBtn = event.target;
    const originalText = saveBtn.innerHTML;
    saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Сохранение...';
    saveBtn.disabled = true;
    
    fetch(`/api/booking/${bookingId}/update/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
        },
        body: JSON.stringify({
            service_id: serviceId,
            client_name: clientName,
            client_phone: clientPhone,
            date: date,
            time: time,
            comment: comment,
            status: status
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('editBookingModal')).hide();
            loadCalendar();
            loadBookings(1, false);
        } else {
            alert(data.error || 'Ошибка при сохранении');
        }
    })
    .catch(error => {
        alert('Произошла ошибка');
    })
    .finally(() => {
        saveBtn.innerHTML = originalText;
        saveBtn.disabled = false;
    });
}

function deleteBooking(bookingId, clientName, time) {
    if (confirm(`Удалить запись клиента "${clientName}" на ${time}?`)) {
        fetch(`/api/booking/${bookingId}/delete/`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                loadCalendar();
                loadBookings(1, false);
                // Если открыто модальное окно дня, закрываем его
                const dayModal = bootstrap.Modal.getInstance(document.getElementById('dayModal'));
                if (dayModal) dayModal.hide();
            } else {
                alert(data.error || 'Ошибка при удалении');
            }
        });
    }
}
</script>

